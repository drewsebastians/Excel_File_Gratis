---
import { getCollection } from "astro:content";
import { siteConfig } from "../config/site";
import { getCategoryUrl, getPopulatedCategories } from "../lib/templates";

const populatedCategories = getPopulatedCategories(await getCollection("templates"));
---

<footer class="site-footer">
  <div class="site-footer__grid container">
    <div>
      <a class="logo" href="/">
        <img src="/assets/brand/main-icon.png" alt={siteConfig.name} width="180" height="60" loading="lazy" />
      </a>
      <p>&copy; 2026 {siteConfig.name}. Semua hak dilindungi undang-undang.</p>
    </div>

    <div>
      <h2>Template</h2>
      <ul>
        <li><a href="/templates/">Semua Template</a></li>
        <li><a href="/kategori/">Semua Kategori</a></li>
        {populatedCategories.map((category) => (
          <li><a href={getCategoryUrl(category.slug)}>{category.name}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h2>Tentang</h2>
      <ul>
        <li><a href="/tentang/">Tentang</a></li>
        <li><a href="/disclaimer/">Disclaimer</a></li>
      </ul>
    </div>

    <div>
      <h2>Legal</h2>
      <ul>
        <li><a href="/privasi/">Kebijakan Privasi</a></li>
      </ul>
      <h2 class="footer-subheading">Discovery</h2>
      <ul>
        <li><a href="/sitemap/">HTML Sitemap</a></li>
      </ul>
    </div>
  </div>
</footer>
