---
interface Props {
  variant?: "contact" | "request";
}

const { variant = "contact" } = Astro.props;
const isRequest = variant === "request";
const formId = isRequest ? "request-template-form" : "contact-form";
const eventPrefix = isRequest ? "request_template" : "contact_form";
---

<section class="contact-panel" aria-labelledby={`${formId}-heading`}>
  <h2 id={`${formId}-heading`}>{isRequest ? "Ceritakan kebutuhan Anda" : "Kirim pesan"}</h2>
  <form id={formId} class="form-grid" novalidate data-form-kind={eventPrefix}>
    <input type="hidden" name="access_key" value="0a112699-e322-49a0-ba61-33b851079562" />
    <input class="honeypot" type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" aria-hidden="true" />
    {isRequest ? (
      <>
        <div class="field"><label for="request-name">Nama <span aria-hidden="true">(opsional)</span></label><input id="request-name" name="name" type="text" autocomplete="name" /></div>
        <div class="field"><label for="request-email">Email <span aria-hidden="true">(opsional)</span></label><input id="request-email" name="email" type="email" autocomplete="email" aria-describedby="request-email-help request-email-error" /><p id="request-email-help" class="field-help">Wajib diisi bila Anda ingin menerima balasan.</p><p id="request-email-error" class="field-error" hidden></p></div>
        <div class="field checkbox-field"><input id="request-reply" name="reply_requested" type="checkbox" /><label for="request-reply">Saya ingin menerima balasan melalui email.</label></div>
        <div class="field"><label for="request-use">Jenis penggunaan <span aria-hidden="true">*</span></label><select id="request-use" name="jenis_penggunaan" required aria-describedby="request-use-error"><option value="">Pilih jenis penggunaan</option><option value="pribadi">Pribadi</option><option value="pekerjaan">Pekerjaan</option><option value="umkm">UMKM</option><option value="pendidikan">Pendidikan</option><option value="rumah-tangga-acara">Rumah tangga atau acara</option><option value="lainnya">Lainnya</option></select><p id="request-use-error" class="field-error" hidden></p></div>
        <div class="field"><label for="request-work">Pekerjaan atau jenis bisnis <span aria-hidden="true">(opsional)</span></label><input id="request-work" name="pekerjaan_atau_bisnis" type="text" /></div>
        <div class="field"><label for="request-problem">Masalah yang ingin diselesaikan <span aria-hidden="true">*</span></label><textarea id="request-problem" name="masalah" required aria-describedby="request-problem-error"></textarea><p id="request-problem-error" class="field-error" hidden></p></div>
        <div class="field"><label for="request-features">Fitur yang dibutuhkan <span aria-hidden="true">*</span></label><textarea id="request-features" name="fitur" required aria-describedby="request-features-error"></textarea><p id="request-features-error" class="field-error" hidden></p></div>
        <div class="field"><label for="request-app">Aplikasi yang digunakan <span aria-hidden="true">*</span></label><input id="request-app" name="aplikasi" type="text" required aria-describedby="request-app-error" placeholder="Contoh: Microsoft Excel atau Google Sheets" /><p id="request-app-error" class="field-error" hidden></p></div>
        <div class="field"><label for="request-version">Versi Excel <span aria-hidden="true">(opsional)</span></label><input id="request-version" name="versi_excel" type="text" /></div>
        <div class="field"><label for="request-urgency">Tingkat urgensi <span aria-hidden="true">(opsional)</span></label><select id="request-urgency" name="urgensi"><option value="">Tidak ingin menyebutkan</option><option value="rendah">Rendah</option><option value="sedang">Sedang</option><option value="tinggi">Tinggi</option></select></div>
      </>
    ) : (
      <>
        <div class="field"><label for="contact-name">Nama <span aria-hidden="true">*</span></label><input id="contact-name" name="name" type="text" autocomplete="name" required aria-describedby="contact-name-error" /><p id="contact-name-error" class="field-error" hidden></p></div>
        <div class="field"><label for="contact-email">Email <span aria-hidden="true">*</span></label><input id="contact-email" name="email" type="email" autocomplete="email" required aria-describedby="contact-email-error" /><p id="contact-email-error" class="field-error" hidden></p></div>
        <div class="field"><label for="contact-type">Jenis pesan <span aria-hidden="true">*</span></label><select id="contact-type" name="jenis_pesan" required aria-describedby="contact-type-error"><option value="">Pilih jenis pesan</option><option value="pertanyaan-umum">Pertanyaan umum</option><option value="file-bermasalah">Melaporkan file bermasalah</option><option value="koreksi-isi">Koreksi isi</option><option value="masukan-website">Masukan website</option><option value="kerja-sama">Kerja sama</option><option value="lainnya">Lainnya</option></select><p id="contact-type-error" class="field-error" hidden></p></div>
        <div class="field"><label for="contact-subject">Subjek <span aria-hidden="true">*</span></label><input id="contact-subject" name="subject" type="text" required aria-describedby="contact-subject-error" /><p id="contact-subject-error" class="field-error" hidden></p></div>
        <div class="field"><label for="contact-message">Pesan <span aria-hidden="true">*</span></label><textarea id="contact-message" name="message" required aria-describedby="contact-message-error"></textarea><p id="contact-message-error" class="field-error" hidden></p></div>
      </>
    )}
    <div class="field checkbox-field"><input id={`${formId}-consent`} name="consent" type="checkbox" required aria-describedby={`${formId}-consent-error`} /><label for={`${formId}-consent`}>Saya setuju data yang saya kirim diproses sesuai <a href="/privasi/">Kebijakan Privasi</a>. <span aria-hidden="true">*</span></label><p id={`${formId}-consent-error`} class="field-error" hidden></p></div>
    <button class="button" type="submit">{isRequest ? "Kirim Request" : "Kirim Pesan"}</button>
    <p class="form-status" role="status" aria-live="polite"></p>
  </form>
</section>

<script>
  document.querySelectorAll("[data-form-kind]").forEach((element) => {
    const form = element as HTMLFormElement;
    const status = form.querySelector(".form-status") as HTMLParagraphElement;
    const submit = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const kind = form.dataset.formKind || "contact_form";
    let started = false;
    const push = (suffix: string) => (window as Window & { ExcelGratisEvents?: { push(name: string, params: Record<string, never>): void } }).ExcelGratisEvents?.push(`${kind}_${suffix}`, {});
    const showError = (input: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement, message: string) => {
      const error = document.getElementById(`${input.id}-error`);
      if (error) { error.textContent = message; error.hidden = false; }
      input.setAttribute("aria-invalid", "true");
    };
    const clearErrors = () => form.querySelectorAll<HTMLElement>(".field-error").forEach((item) => { item.textContent = ""; item.hidden = true; });
    form.addEventListener("focusin", () => { if (!started) { started = true; push("start"); } });
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      clearErrors();
      form.querySelectorAll("[aria-invalid]").forEach((input) => input.removeAttribute("aria-invalid"));
      const inputs = [...form.querySelectorAll("input, select, textarea")] as Array<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>;
      const reply = form.querySelector('[name="reply_requested"]') as HTMLInputElement | null;
      const email = form.querySelector('[name="email"]') as HTMLInputElement | null;
      if (reply?.checked && email && !email.value.trim()) { showError(email, "Masukkan email untuk menerima balasan."); email.focus(); return; }
      const invalid = inputs.find((input) => !input.checkValidity());
      if (invalid) { showError(invalid, invalid.validity.valueMissing ? "Kolom ini wajib diisi." : "Masukkan nilai yang valid."); invalid.focus(); return; }
      submit.disabled = true;
      submit.textContent = "Mengirim...";
      status.textContent = "";
      status.className = "form-status";
      push("submit");
      try {
        const response = await fetch("https://api.web3forms.com/submit", { method: "POST", headers: { Accept: "application/json" }, body: new FormData(form) });
        const data = await response.json();
        if (!data.success) throw new Error("provider rejected submission");
        status.textContent = "Terima kasih. Pesan Anda sudah terkirim.";
        status.classList.add("form-success");
        form.reset();
        push("success");
      } catch {
        status.textContent = "Pesan belum terkirim. Periksa koneksi lalu coba kembali.";
        status.classList.add("form-error");
        push("error");
      } finally {
        submit.disabled = false;
        submit.textContent = form.id === "request-template-form" ? "Kirim Request" : "Kirim Pesan";
      }
    });
  });
</script>
