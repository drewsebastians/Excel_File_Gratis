---
interface Props {
  variant?: "contact" | "request";
}

const { variant = "contact" } = Astro.props;
const isRequest = variant === "request";
const formId = isRequest ? "request-template-form" : "contact-form";
const eventPrefix = isRequest ? "request_template" : "contact_form";
const formType = isRequest ? "request_template" : "contact";
const providerSubject = isRequest ? "[Request Template ExcelGratis] Request baru" : "[Kontak ExcelGratis] Pesan baru";
---

<section class="contact-panel" aria-labelledby={`${formId}-heading`}>
  <h2 id={`${formId}-heading`}>{isRequest ? "Ceritakan kebutuhan Anda" : "Kirim pesan"}</h2>
  <form id={formId} class="form-grid" novalidate data-form-kind={eventPrefix} data-form-type={formType}>
    <input type="hidden" name="access_key" value="0a112699-e322-49a0-ba61-33b851079562" />
    <input type="hidden" name="form_type" value={formType} />
    <input type="hidden" name="from_name" value="ExcelGratis Website" />
    <input type="hidden" name="subject" value={providerSubject} />
    <input class="honeypot" type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" aria-hidden="true" />
    {isRequest ? (
      <>
        <div class="field"><label for="request-name">Nama <span aria-hidden="true">(opsional)</span></label><input id="request-name" name="name" type="text" autocomplete="name" maxlength="100" /></div>
        <div class="field"><label for="request-email">Email <span aria-hidden="true">(opsional)</span></label><input id="request-email" name="email" type="email" autocomplete="email" maxlength="254" aria-describedby="request-email-help request-email-error" /><p id="request-email-help" class="field-help">Wajib diisi bila Anda ingin menerima balasan.</p><p id="request-email-error" class="field-error" hidden></p></div>
        <div class="field checkbox-field"><input id="request-reply" name="reply_requested" type="checkbox" /><label for="request-reply">Saya ingin menerima balasan melalui email.</label></div>
        <div class="field"><label for="request-use">Jenis penggunaan <span aria-hidden="true">*</span></label><select id="request-use" name="jenis_penggunaan" required aria-describedby="request-use-error"><option value="">Pilih jenis penggunaan</option><option value="pribadi">Pribadi</option><option value="pekerjaan">Pekerjaan</option><option value="umkm">UMKM</option><option value="pendidikan">Pendidikan</option><option value="rumah-tangga-acara">Rumah tangga atau acara</option><option value="lainnya">Lainnya</option></select><p id="request-use-error" class="field-error" hidden></p></div>
        <div class="field"><label for="request-work">Pekerjaan atau jenis bisnis <span aria-hidden="true">(opsional)</span></label><input id="request-work" name="pekerjaan_atau_bisnis" type="text" maxlength="160" /></div>
        <div class="field"><label for="request-problem">Masalah yang ingin diselesaikan <span aria-hidden="true">*</span></label><textarea id="request-problem" name="masalah" required minlength="10" maxlength="5000" aria-describedby="request-problem-error"></textarea><p id="request-problem-error" class="field-error" hidden></p></div>
        <div class="field"><label for="request-features">Fitur yang dibutuhkan <span aria-hidden="true">*</span></label><textarea id="request-features" name="fitur" required minlength="3" maxlength="3000" aria-describedby="request-features-error"></textarea><p id="request-features-error" class="field-error" hidden></p></div>
        <div class="field"><label for="request-app">Aplikasi yang digunakan <span aria-hidden="true">*</span></label><input id="request-app" name="aplikasi" type="text" required minlength="2" maxlength="120" aria-describedby="request-app-error" placeholder="Contoh: Microsoft Excel atau Google Sheets" /><p id="request-app-error" class="field-error" hidden></p></div>
        <div class="field"><label for="request-version">Versi Excel <span aria-hidden="true">(opsional)</span></label><input id="request-version" name="versi_excel" type="text" maxlength="80" /></div>
        <div class="field"><label for="request-urgency">Tingkat urgensi <span aria-hidden="true">(opsional)</span></label><select id="request-urgency" name="urgensi"><option value="">Tidak ingin menyebutkan</option><option value="rendah">Rendah</option><option value="sedang">Sedang</option><option value="tinggi">Tinggi</option></select></div>
      </>
    ) : (
      <>
        <div class="field"><label for="contact-name">Nama <span aria-hidden="true">*</span></label><input id="contact-name" name="name" type="text" autocomplete="name" required minlength="2" maxlength="100" aria-describedby="contact-name-error" /><p id="contact-name-error" class="field-error" hidden></p></div>
        <div class="field"><label for="contact-email">Email <span aria-hidden="true">*</span></label><input id="contact-email" name="email" type="email" autocomplete="email" required maxlength="254" aria-describedby="contact-email-error" /><p id="contact-email-error" class="field-error" hidden></p></div>
        <div class="field"><label for="contact-type">Jenis pesan <span aria-hidden="true">*</span></label><select id="contact-type" name="jenis_pesan" required aria-describedby="contact-type-error"><option value="">Pilih jenis pesan</option><option value="pertanyaan-umum">Pertanyaan umum</option><option value="file-bermasalah">Melaporkan file bermasalah</option><option value="koreksi-isi">Koreksi isi</option><option value="masukan-website">Masukan website</option><option value="kerja-sama">Kerja sama</option><option value="lainnya">Lainnya</option></select><p id="contact-type-error" class="field-error" hidden></p></div>
        <div class="field"><label for="contact-subject">Subjek <span aria-hidden="true">*</span></label><input id="contact-subject" name="user_subject" type="text" required minlength="3" maxlength="160" aria-describedby="contact-subject-error" /><p id="contact-subject-error" class="field-error" hidden></p></div>
        <div class="field"><label for="contact-message">Pesan <span aria-hidden="true">*</span></label><textarea id="contact-message" name="message" required minlength="10" maxlength="5000" aria-describedby="contact-message-error"></textarea><p id="contact-message-error" class="field-error" hidden></p></div>
      </>
    )}
    <div class="field checkbox-field"><input id={`${formId}-consent`} name="consent" type="checkbox" required aria-describedby={`${formId}-consent-error`} /><label for={`${formId}-consent`}>Saya setuju data yang saya kirim diproses sesuai <a href="/privasi/">Kebijakan Privasi</a>. <span aria-hidden="true">*</span></label><p id={`${formId}-consent-error`} class="field-error" hidden></p></div>
    <button class="button" type="submit" data-idle-label={isRequest ? "Kirim Request" : "Kirim Pesan"}>{isRequest ? "Kirim Request" : "Kirim Pesan"}</button>
    <p class="form-status" role="status" aria-live="polite" tabindex="-1"></p>
  </form>
</section>

<script>
  import {
    createFormEventParams,
    createSubmissionGuard,
    normalizeText,
    prepareSubmissionData,
    submitWeb3Form,
  } from "../lib/form-submission.mjs";

  const errorMessages: Record<string, string> = {
    bad_request: "Pesan belum dapat dikirim karena data ditolak layanan. Periksa isian lalu coba kembali.",
    provider_configuration: "Pesan belum dapat dikirim karena konfigurasi layanan belum menerima pengiriman. Coba kembali beberapa saat lagi.",
    provider_rejected: "Pesan belum dapat dikirim karena data belum diterima layanan. Periksa isian lalu coba kembali.",
    rate_limited: "Terlalu banyak percobaan dalam waktu singkat. Tunggu beberapa saat lalu coba kembali.",
    provider_unavailable: "Layanan pengiriman sedang bermasalah. Coba kembali beberapa saat lagi.",
    http_error: "Pesan belum dapat dikirim oleh layanan. Coba kembali beberapa saat lagi.",
    offline: "Perangkat sedang offline. Sambungkan ke internet lalu coba kembali.",
    network: "Koneksi ke layanan pengiriman terputus. Periksa koneksi lalu coba kembali.",
    timeout: "Pengiriman melewati batas waktu. Periksa koneksi lalu coba kembali.",
    invalid_json: "Layanan mengirim respons yang tidak dapat dikonfirmasi. Pesan belum dianggap terkirim.",
    unexpected_response: "Layanan mengirim respons yang tidak dapat dikonfirmasi. Pesan belum dianggap terkirim.",
    client_error: "Terjadi kendala saat menyiapkan pesan. Isian Anda tetap tersimpan untuk dicoba kembali.",
  };

  document.querySelectorAll("[data-form-kind]").forEach((element) => {
    const form = element as HTMLFormElement;
    const status = form.querySelector(".form-status") as HTMLParagraphElement;
    const submit = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const kind = form.dataset.formKind || "contact_form";
    const formType = form.dataset.formType === "request_template" ? "request_template" : "contact";
    const idleLabel = submit.dataset.idleLabel || "Kirim";
    const guard = createSubmissionGuard();
    let activeRequest: AbortController | null = null;
    let started = false;

    const push = (suffix: string, params: Record<string, string | number> = {}) => {
      (window as Window & { ExcelGratisEvents?: { push(name: string, params: Record<string, string | number>): void } })
        .ExcelGratisEvents?.push(`${kind}_${suffix}`, params);
    };
    const showStatus = (message: string, state: "loading" | "success" | "error", focus = false) => {
      status.textContent = message;
      status.className = "form-status";
      status.setAttribute("role", state === "error" ? "alert" : "status");
      status.setAttribute("aria-live", state === "error" ? "assertive" : "polite");
      if (state === "success") status.classList.add("form-success");
      if (state === "error") status.classList.add("form-error");
      if (focus) status.focus();
    };
    const showError = (input: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement, message: string) => {
      const error = document.getElementById(`${input.id}-error`);
      if (error) { error.textContent = message; error.hidden = false; }
      input.setAttribute("aria-invalid", "true");
    };
    const clearErrors = () => {
      form.querySelectorAll<HTMLElement>(".field-error").forEach((item) => { item.textContent = ""; item.hidden = true; });
      form.querySelectorAll("[aria-invalid]").forEach((input) => input.removeAttribute("aria-invalid"));
    };
    const validationMessage = (input: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement) => {
      if (input.validity.valueMissing) return "Kolom ini wajib diisi.";
      if (input.validity.typeMismatch) return "Masukkan email yang valid.";
      if (input instanceof HTMLInputElement || input instanceof HTMLTextAreaElement) {
        if (input.validity.tooShort || (input.minLength > 0 && input.value.length < input.minLength)) {
          return `Gunakan minimal ${input.minLength} karakter.`;
        }
        if (input.validity.tooLong || (input.maxLength > 0 && input.value.length > input.maxLength)) {
          return `Gunakan maksimal ${input.maxLength} karakter.`;
        }
      }
      return input.checkValidity() ? "" : "Masukkan nilai yang valid.";
    };

    form.addEventListener("focusin", () => {
      if (!started) {
        started = true;
        push("start", createFormEventParams({ formType, status: "started" }));
      }
    });
    window.addEventListener("pagehide", () => activeRequest?.abort());

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!guard.begin()) return;

      clearErrors();
      status.textContent = "";
      status.className = "form-status";

      form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input[type="text"], input[type="email"], textarea')
        .forEach((input) => { input.value = normalizeText(input.value); });

      const inputs = [...form.querySelectorAll("input, select, textarea")] as Array<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>;
      const reply = form.querySelector('[name="reply_requested"]') as HTMLInputElement | null;
      const email = form.querySelector('[name="email"]') as HTMLInputElement | null;
      const invalid = new Map<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement, string>();
      if (reply?.checked && email && !email.value) invalid.set(email, "Masukkan email untuk menerima balasan.");
      for (const input of inputs) {
        const message = validationMessage(input);
        if (message && !invalid.has(input)) invalid.set(input, message);
      }
      if (invalid.size > 0) {
        for (const [input, message] of invalid) showError(input, message);
        showStatus(`Periksa kembali ${invalid.size} kolom yang ditandai.`, "error", true);
        push("error", createFormEventParams({
          formType,
          status: "error",
          errorCategory: "validation",
          validationErrorCount: invalid.size,
        }));
        guard.end();
        return;
      }

      submit.disabled = true;
      submit.textContent = "Mengirim...";
      showStatus("Sedang mengirim pesan...", "loading");
      push("submit", createFormEventParams({ formType, status: "submitting" }));
      activeRequest = new AbortController();

      try {
        const result = await submitWeb3Form({
          formData: prepareSubmissionData(new FormData(form), formType),
          externalSignal: activeRequest.signal,
          isOnline: navigator.onLine,
        });

        if (result.ok) {
          form.reset();
          showStatus("Terima kasih. Pesan Anda sudah dikonfirmasi terkirim.", "success", true);
          push("success", createFormEventParams({ formType, status: "success" }));
        } else if (result.errorCategory !== "cancelled") {
          const errorCategory = result.errorCategory || "client_error";
          showStatus(errorMessages[errorCategory] || errorMessages.client_error, "error", true);
          push("error", createFormEventParams({ formType, status: "error", errorCategory }));
        }
      } catch {
        showStatus(errorMessages.client_error, "error", true);
        push("error", createFormEventParams({ formType, status: "error", errorCategory: "client_error" }));
      } finally {
        activeRequest = null;
        guard.end();
        submit.disabled = false;
        submit.textContent = idleLabel;
      }
    });
  });
</script>
