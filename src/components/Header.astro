---
import Icon from "./Icon.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../config/site";
import { getPublishedResources, resourceNavigationAvailable, type ResourceEntries } from "../lib/resources";

const path = Astro.url.pathname;
const isCategory = path.startsWith("/kategori/");
const isTemplate = path.startsWith("/templates/");
const isInfo = path.startsWith("/tentang");
const resources: ResourceEntries = {
  guides: getPublishedResources(await getCollection("guides")),
  formulas: getPublishedResources(await getCollection("formulas")),
  troubleshooting: getPublishedResources(await getCollection("troubleshooting")),
  resourceCollections: getPublishedResources(await getCollection("resourceCollections")),
};
const learningAvailable = resourceNavigationAvailable(resources).filter((kind) => kind !== "resourceCollections").length > 0;
---

<header class="site-header">
  <div class="site-header__inner container">
    <a class="logo" href="/" aria-label={`${siteConfig.name} beranda`}>
      <img src="/assets/brand/main-icon.png" alt={siteConfig.name} width="180" height="60" />
    </a>

    <nav class="desktop-nav" aria-label="Navigasi utama">
      <a href="/templates/" aria-current={isTemplate ? "page" : undefined}>Template</a>
      <a href="/kategori/" aria-current={isCategory ? "page" : undefined}>Kategori</a>
      {learningAvailable && <a href="/belajar-excel/" aria-current={path.startsWith("/belajar-excel/") || path.startsWith("/panduan/") || path.startsWith("/rumus-excel/") || path.startsWith("/masalah-excel/") ? "page" : undefined}>Belajar Excel</a>}
      <a href="/tentang/" aria-current={isInfo ? "page" : undefined}>Tentang</a>
      <a href="/templates/#template-search">Cari</a>
    </nav>

    <div class="header-actions">
      <form class="header-search" action="/templates/" method="get" role="search">
        <Icon name="search" />
        <input name="q" type="search" placeholder="Cari template..." aria-label="Cari template" />
      </form>
      <a class="icon-link mobile-only" href="/templates/#template-search" aria-label="Cari template">
        <Icon name="search" />
      </a>
    </div>
  </div>
</header>
