---
import Icon from "./Icon.astro";
import { categories, siteConfig } from "../config/site";

const path = Astro.url.pathname;
const kategoriHref = `/kategori/${categories[0].slug}/`;
const isCategory = path.startsWith("/kategori/");
const isInfo = path.startsWith("/tentang") || path.startsWith("/privasi");
---

<header class="site-header">
  <div class="site-header__inner container">
    <a class="logo" href="/" aria-label={`${siteConfig.name} beranda`}>
      <img src="/assets/brand/main-icon.png" alt={siteConfig.name} width="180" height="60" />
    </a>

    <nav class="desktop-nav" aria-label="Navigasi utama">
      <a href={kategoriHref} aria-current={isCategory ? "page" : undefined}>Kategori</a>
      <a href="/tentang/" aria-current={isInfo ? "page" : undefined}>Tentang</a>
    </nav>

    <div class="header-actions">
      <form class="header-search" action={kategoriHref} method="get" role="search">
        <Icon name="search" />
        <input name="q" type="search" placeholder="Cari template..." aria-label="Cari template" />
      </form>
      <a class="icon-link mobile-only" href={kategoriHref} aria-label="Buka kategori">
        <Icon name="menu" />
      </a>
    </div>
  </div>
</header>
