---
import Icon from "./Icon.astro";

const path = Astro.url.pathname;
const links = [
  { href: "/", label: "Beranda", icon: "home", active: path === "/" },
  { href: "/templates/", label: "Template", icon: "table_chart", active: path.startsWith("/templates/") },
  { href: "/templates/#template-search", label: "Cari", icon: "search", active: false },
  {
    href: "/kategori/",
    label: "Kategori",
    icon: "category",
    active: path.startsWith("/kategori/"),
  },
];
---

<nav class="bottom-nav" aria-label="Navigasi bawah">
  {links.map((link) => (
    <a href={link.href} aria-current={link.active ? "page" : undefined}>
      <Icon name={link.icon} />
      <span>{link.label}</span>
    </a>
  ))}
</nav>
