---
import Icon from "./Icon.astro";

interface Props {
  title: string;
  excerpt: string;
  category: string;
  href: string;
  image: string;
  imageAlt: string;
  downloads?: string;
  fileType?: string;
  variant?: "grid" | "list" | "related";
}

const {
  title,
  excerpt,
  category,
  href,
  image,
  imageAlt,
  downloads,
  fileType = "xlsx",
  variant = "grid",
} = Astro.props;

const fileBadge = fileType.startsWith(".") ? fileType : `.${fileType}`;
---

<article class={`template-card template-card--${variant}`}>
  <a class="template-card__media" href={href} aria-label={title}>
    <img src={image} alt={imageAlt} loading="lazy" />
    <span class="file-badge"><Icon name="table_chart" /> {fileBadge}</span>
  </a>
  <div class="template-card__body">
    <span class="chip">{category}</span>
    <h3><a href={href}>{title}</a></h3>
    <p>{excerpt}</p>
    {downloads && (
      <div class="template-card__meta">
        <span><Icon name="download" /> {downloads}</span>
      </div>
    )}
  </div>
</article>
