---
import Icon from "./Icon.astro";

interface Props {
  title: string;
  excerpt: string;
  category: string;
  href: string;
  image: string;
  imageAlt: string;
  ctaLabel?: string;
  downloadHref?: string;
  downloads?: string;
  variant?: "grid" | "list" | "related";
}

const {
  title,
  excerpt,
  category,
  href,
  image,
  imageAlt,
  ctaLabel = "Lihat Template",
  downloadHref,
  downloads,
  variant = "grid",
} = Astro.props;

const actionHref = downloadHref || href;
const actionLabel = downloadHref ? "Download Gratis" : ctaLabel;
---

<article class={`template-card template-card--${variant}`}>
  <a class="template-card__media" href={href} aria-label={title}>
    <img src={image} alt={imageAlt} loading="lazy" />
    <span class="file-badge"><Icon name="table_chart" /> .xlsx</span>
  </a>
  <div class="template-card__body">
    <span class="chip">{category}</span>
    <h3><a href={href}>{title}</a></h3>
    <p>{excerpt}</p>
    {downloads && (
      <div class="template-card__meta">
        <span><Icon name="download" /> {downloads}</span>
      </div>
    )}
    <div class="template-card__actions">
      <a
        class={downloadHref ? "button" : "button-outline"}
        href={actionHref}
        download={downloadHref ? true : undefined}
      >
        <Icon name={downloadHref ? "download" : "arrow_forward"} />
        <span>{actionLabel}</span>
      </a>
    </div>
  </div>
</article>
