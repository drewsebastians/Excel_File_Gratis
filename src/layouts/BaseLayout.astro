---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BottomNav from "../components/BottomNav.astro";
import EventLayer from "../components/EventLayer.astro";
import { defaultOgImage } from "../config/images";
import { siteConfig } from "../config/site";
import "../styles/global.css";

type StructuredData = Record<string, unknown> | Array<Record<string, unknown>>;

interface Props {
  title: string;
  description: string;
  path?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  structuredData?: StructuredData;
  robots?: string;
  bodyClass?: string;
}

const {
  title,
  description,
  path = Astro.url.pathname,
  ogImage = defaultOgImage,
  ogType = "website",
  structuredData,
  robots = "index, follow",
  bodyClass = "",
} = Astro.props;

const pageTitle = title.includes(siteConfig.name) ? title : `${title} - ${siteConfig.name}`;
const baseUrl = Astro.site?.toString() || siteConfig.url;
const canonicalPath = path.split("?")[0] || "/";
const canonicalUrl = new URL(canonicalPath, baseUrl).toString();
const ogImageUrl = ogImage.startsWith("http") ? ogImage : new URL(ogImage, baseUrl).toString();
const jsonLd = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" sizes="642x642" href="/favicon.png" />
    <link rel="shortcut icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="642x642" href="/assets/brand/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#006130" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="id_ID" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Plus+Jakarta+Sans:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    {jsonLd.map((item) => <script type="application/ld+json" is:inline set:html={JSON.stringify(item)} />)}
  </head>
  <body class={`has-mobile-nav ${bodyClass}`}>
    <a class="skip-link" href="#content">Lewati ke konten utama</a>
    <Header />
    <main id="content">
      <slot />
    </main>
    <Footer />
    <BottomNav />
    <EventLayer />
  </body>
</html>
