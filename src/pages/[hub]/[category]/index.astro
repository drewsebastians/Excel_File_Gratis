---
import { getCollection } from "astro:content";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import ResourceCard from "../../../components/ResourceCard.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getBreadcrumbStructuredData, getPublishedResources, getResourceCategoryName, getResourceHubUrl, resourceKinds, type ArticleResourceKind, type ResourceEntry } from "../../../lib/resources";

export async function getStaticPaths() {
  const articleKinds = Object.keys(resourceKinds).filter((kind) => kind !== "resourceCollections") as ArticleResourceKind[];
  const paths: Array<{ params: { hub: string; category: string }; props: { kind: ArticleResourceKind; key: string } }> = [];
  for (const kind of articleKinds) {
    for (const entry of getPublishedResources(await getCollection(kind))) {
      const key = `${kind}:${entry.data.category}`;
      if (!paths.some((path) => path.props.key === key)) paths.push({ params: { hub: resourceKinds[kind].hub, category: entry.data.category }, props: { kind, key } });
    }
  }
  return paths;
}
const { kind } = Astro.props as { kind: ArticleResourceKind };
const category = Astro.params.category || "";
const entries = getPublishedResources(await getCollection(kind)).filter((entry) => entry.data.category === category) as ResourceEntry[];
const categoryName = getResourceCategoryName(kind, category);
const categoryPath = `${getResourceHubUrl(kind)}${category}/`;
const structuredData = [
  getBreadcrumbStructuredData([
    { label: "Beranda", path: "/" },
    { label: resourceKinds[kind].label, path: getResourceHubUrl(kind) },
    { label: categoryName, path: categoryPath },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: `${categoryName} ${resourceKinds[kind].label}`,
    mainEntity: {
      "@type": "ItemList",
      itemListElement: entries.map((entry, index) => ({ "@type": "ListItem", position: index + 1, name: entry.data.title })),
    },
  },
];
---

<BaseLayout title={`${categoryName} ${resourceKinds[kind].label}`} description={`Resource ${categoryName} yang tersedia di ExcelGratis.`} path={categoryPath} structuredData={structuredData}>
  <section class="info-layout container">
    <header class="info-header"><Breadcrumbs items={[{ label: "Beranda", href: "/" }, { label: resourceKinds[kind].label, href: getResourceHubUrl(kind) }, { label: categoryName }]} /><h1>{categoryName}</h1><p>Resource {resourceKinds[kind].label.toLowerCase()} yang sudah tersedia.</p></header>
    <div class="resource-grid">{entries.map((entry) => <ResourceCard entry={entry} kind={kind} />)}</div>
  </section>
</BaseLayout>
