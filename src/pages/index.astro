---
import { getCollection } from "astro:content";
import Icon from "../components/Icon.astro";
import TemplateCard from "../components/TemplateCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
import { templateImages } from "../config/images";
import {
  getExcerpt,
  getFeaturedTemplates,
  getPopulatedCategories,
  getPublishedTemplates,
  getTemplateFileBadge,
  getTemplateImage,
  getTemplateImageAlt,
  getTemplateUrl,
  sortTemplates,
} from "../lib/templates";

const templates = sortTemplates(getPublishedTemplates(await getCollection("templates")));
const latest = templates.slice(0, 4);
const featuredTemplates = getFeaturedTemplates(templates, 4);
const populatedCategories = getPopulatedCategories(templates);
const title = "Template Excel Gratis, Siap Pakai";
const description = siteConfig.description;
---

<BaseLayout title={title} description={description} path="/" ogImage={templateImages.budgetHero}>
  <section class="hero container">
    <h1>Template Excel Gratis, <span>Siap Pakai</span></h1>
    <p>Template Excel untuk keuangan, bisnis, dan produktivitas - download gratis, tanpa perlu daftar.</p>
    <form class="search-panel" action="/templates/" method="get" role="search">
      <Icon name="search" />
      <input name="q" type="search" placeholder="Cari template... misal: anggaran bulanan" aria-label="Cari template" />
      <button class="button" type="submit">Cari</button>
    </form>
    <div class="hero-actions">
      <a class="button" href="/templates/">Lihat Semua Template</a>
      <a class="button-outline" href="/kategori/">Lihat Kategori</a>
    </div>
  </section>

  <section class="section container" aria-labelledby="popular-category-heading">
    <div class="section-heading">
      <h2 id="popular-category-heading">Kategori Tersedia</h2>
      <a href="/kategori/">Lihat Semua <Icon name="arrow_forward" /></a>
    </div>
    <div class="category-grid">
      {populatedCategories.map((category) => (
        <a class="category-card" href={`/kategori/${category.slug}/`} data-event="category_click" data-event-param-category-slug={category.slug}>
          <span class="category-card__icon"><Icon name={category.icon} /></span>
          <span>{category.name}</span>
          <small>{category.count} template</small>
        </a>
      ))}
    </div>
  </section>

  <section class="section container" aria-labelledby="featured-template-heading">
    <div class="section-heading">
      <h2 id="featured-template-heading">Template Pilihan</h2>
      <a href="/templates/">Lihat Semua <Icon name="arrow_forward" /></a>
    </div>
    <div class="template-grid">
      {featuredTemplates.map((entry) => (
        <TemplateCard
          title={entry.data.title}
          excerpt={getExcerpt(entry.body)}
          category={populatedCategories.find((category) => category.slug === entry.data.category)?.shortName || "Template"}
          href={getTemplateUrl(entry)}
          image={getTemplateImage(entry)}
          imageAlt={getTemplateImageAlt(entry)}
          downloads="Detail template"
          fileType={getTemplateFileBadge(entry)}
        />
      ))}
    </div>
  </section>

  <section class="section container" aria-labelledby="latest-template-heading">
    <div class="section-heading">
      <h2 id="latest-template-heading">Template Terbaru</h2>
      <a href="/templates/">
        Lihat Semua <Icon name="arrow_forward" />
      </a>
    </div>
    <div class="template-grid">
      {latest.map((entry) => (
        <TemplateCard
          title={entry.data.title}
          excerpt={getExcerpt(entry.body)}
          category={populatedCategories.find((category) => category.slug === entry.data.category)?.shortName || "Template"}
          href={getTemplateUrl(entry)}
          image={getTemplateImage(entry)}
          imageAlt={getTemplateImageAlt(entry)}
          downloads="Detail template"
          fileType={getTemplateFileBadge(entry)}
        />
      ))}
    </div>
  </section>

  <section class="section container trust-section" aria-labelledby="trust-heading">
    <h2 id="trust-heading">Praktis untuk kebutuhan harian</h2>
    <p>Setiap template disiapkan sebagai file spreadsheet statis yang bisa langsung diunduh, dibuka di Excel atau Google Sheets, lalu disesuaikan dengan kebutuhanmu sendiri.</p>
  </section>
</BaseLayout>
