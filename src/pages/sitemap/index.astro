---
import { getCollection } from "astro:content";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPopulatedCategories, getPublishedTemplates, getTemplateUrl, sortTemplates } from "../../lib/templates";
import { getPublishedResources, getResourceHubUrl, resourceKinds, resourceNavigationAvailable, type ResourceEntries } from "../../lib/resources";

const allTemplates = await getCollection("templates");
const templates = sortTemplates(getPublishedTemplates(allTemplates));
const populatedCategories = getPopulatedCategories(allTemplates);
const resources: ResourceEntries = {
  guides: getPublishedResources(await getCollection("guides")),
  formulas: getPublishedResources(await getCollection("formulas")),
  troubleshooting: getPublishedResources(await getCollection("troubleshooting")),
  resourceCollections: getPublishedResources(await getCollection("resourceCollections")),
};
const availableResources = resourceNavigationAvailable(resources);
const title = "Sitemap HTML";
const description = "Daftar halaman utama, kategori, dan template Excel gratis yang tersedia di ExcelGratis.";
---

<BaseLayout title={title} description={description} path="/sitemap/">
  <section class="info-layout container">
    <header class="info-header">
      <Breadcrumbs items={[{ label: "Beranda", href: "/" }, { label: "Sitemap HTML" }]} />
      <h1>Sitemap HTML</h1>
      <p>Gunakan halaman ini untuk menemukan halaman utama, kategori, dan template yang sudah tersedia.</p>
    </header>

    <div class="sitemap-grid">
      <section>
        <h2>Halaman Utama</h2>
        <ul>
          <li><a href="/">Beranda</a></li>
          <li><a href="/templates/">Semua Template</a></li>
          <li><a href="/kategori/">Semua Kategori</a></li>
          <li><a href="/belajar-excel/">Belajar Excel</a></li>
          {availableResources.map((kind) => <li><a href={getResourceHubUrl(kind)}>{resourceKinds[kind].label}</a></li>)}
        </ul>
      </section>

      <section>
        <h2>Kategori</h2>
        <ul>
          {populatedCategories.map((category) => (
            <li><a href={`/kategori/${category.slug}/`}>{category.name}</a></li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Template</h2>
        <ul>
          {templates.map((entry) => (
            <li><a href={getTemplateUrl(entry)}>{entry.data.title}</a></li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Tentang dan Legal</h2>
        <ul>
          <li><a href="/tentang/">Tentang</a></li>
          <li><a href="/kontak/">Kontak</a></li>
          <li><a href="/kebijakan-editorial/">Kebijakan Editorial</a></li>
          <li><a href="/cara-kami-menguji-template/">Cara Kami Menguji Template</a></li>
          <li><a href="/lisensi-template/">Lisensi Template</a></li>
          <li><a href="/syarat-ketentuan/">Syarat dan Ketentuan</a></li>
          <li><a href="/privasi/">Kebijakan Privasi</a></li>
          <li><a href="/kebijakan-cookie/">Kebijakan Cookie</a></li>
          <li><a href="/disclaimer/">Disclaimer</a></li>
        </ul>
      </section>
    </div>
  </section>
</BaseLayout>
