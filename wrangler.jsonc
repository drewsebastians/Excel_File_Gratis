{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "excelfilegratis",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-06",
  "build": {
    "command": "pnpm run build"
  },
  "routes": [
    {
      "pattern": "excelgratis.my.id",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  }
}
